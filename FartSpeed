-- PÁGINA: ESP (ferramenta de moderação / anti-cheat visual)
------------------------------------------------------------
-- Mostra Nome, Distância, Vida e Velocidade real de cada jogador.
-- Quando a velocidade observada estiver muito acima do normal,
-- o texto e o contorno ficam vermelhos, ajudando você a notar
-- possíveis speed hacks enquanto modera o seu jogo.
-- OBS: isso é só visual, roda no cliente. Para banir/agir de forma
-- confiável é preciso validar no servidor (o cliente pode ser enganado).

local ESP_SPEED_THRESHOLD = 40 -- acima disso, marca como suspeito

local EspPage = newPage("Esp", false)
newLabel(EspPage, "Esp", UDim2.new(0, 120, 0, 20), UDim2.new(0, 44, 0, 10), 15, true)
newLabel(EspPage, "Enable esp", UDim2.new(0, 120, 0, 20), UDim2.new(0, 20, 0, 55), 14, false)

local espEntries = {} -- [char] = {Highlight=, Billboard=, NameLabel=, InfoLabel=, Player=}
local espUpdateConn

local function clearEsp()
    for _, data in pairs(espEntries) do
        if data.Highlight then data.Highlight:Destroy() end
        if data.Billboard then data.Billboard:Destroy() end
    end
    espEntries = {}
    if espUpdateConn then espUpdateConn:Disconnect(); espUpdateConn = nil end
end

local function addEspToCharacter(char, plr)
    if espEntries[char] then return end

    local hl = Instance.new("Highlight")
    hl.FillColor = Themes[State.CurrentTheme].Accent
    hl.FillTransparency = 0.65
    hl.OutlineColor = Color3.fromRGB(255,255,255)
    hl.Parent = char

    local head = char:FindFirstChild("Head") or char:WaitForChild("Head", 2)
    local billboard = Instance.new("BillboardGui")
    billboard.Name = "EspInfo"
    billboard.Size = UDim2.new(0, 160, 0, 44)
    billboard.StudsOffset = Vector3.new(0, 2.2, 0)
    billboard.AlwaysOnTop = true
    billboard.Adornee = head
    billboard.Parent = head or char

    local nameLabel = Instance.new("TextLabel")
    nameLabel.Size = UDim2.new(1, 0, 0, 18)
    nameLabel.BackgroundTransparency = 1
    nameLabel.Font = Enum.Font.GothamBold
    nameLabel.TextSize = 14
    nameLabel.TextColor3 = Color3.fromRGB(255,255,255)
    nameLabel.TextStrokeTransparency = 0.4
    nameLabel.Text = plr and plr.Name or "?"
    nameLabel.Parent = billboard

    local infoLabel = Instance.new("TextLabel")
    infoLabel.Size = UDim2.new(1, 0, 0, 24)
    infoLabel.Position = UDim2.new(0, 0, 0, 18)
    infoLabel.BackgroundTransparency = 1
    infoLabel.Font = Enum.Font.Gotham
    infoLabel.TextSize = 12
    infoLabel.TextColor3 = Color3.fromRGB(220,220,225)
    infoLabel.TextStrokeTransparency = 0.5
    infoLabel.Text = "..."
    infoLabel.Parent = billboard

    espEntries[char] = {
        Highlight = hl,
        Billboard = billboard,
        NameLabel = nameLabel,
        InfoLabel = infoLabel,
        Player = plr,
    }
end

local function startEspUpdateLoop()
    if espUpdateConn then return end
    espUpdateConn = RunService.Heartbeat:Connect(function()
        if not State.EspEnabled then return end
        local myChar = LocalPlayer.Character
        local myRoot = myChar and myChar:FindFirstChild("HumanoidRootPart")

        for char, data in pairs(espEntries) do
            if not char.Parent then
                -- personagem saiu / morreu, limpa a entrada
                if data.Highlight then data.Highlight:Destroy() end
                if data.Billboard then data.Billboard:Destroy() end
                espEntries[char] = nil
            else
                local root = char:FindFirstChild("HumanoidRootPart")
                local hum = char:FindFirstChildOfClass("Humanoid")
                if root and hum then
                    -- distância
                    local distance = myRoot and (myRoot.Position - root.Position).Magnitude or 0

                    -- velocidade real observada (horizontal), não apenas a propriedade WalkSpeed
                    local vel = root.AssemblyLinearVelocity
                    local horizontalSpeed = Vector3.new(vel.X, 0, vel.Z).Magnitude

                    local suspicious = horizontalSpeed > ESP_SPEED_THRESHOLD
                    local color = suspicious and Color3.fromRGB(255, 80, 80) or Color3.fromRGB(220,220,225)

                    data.InfoLabel.TextColor3 = color
                    data.Highlight.OutlineColor = suspicious and Color3.fromRGB(255,60,60) or Color3.fromRGB(255,255,255)
                    data.Highlight.FillColor = suspicious and Color3.fromRGB(255,60,60) or Themes[State.CurrentTheme].Accent

                    data.InfoLabel.Text = string.format(
                        "%dm | HP %d/%d | Vel %d%s",
                        math.floor(distance),
                        math.floor(hum.Health),
                        math.floor(hum.MaxHealth),
                        math.floor(horizontalSpeed),
                        suspicious and " ⚠" or ""
                    )
                end
            end
        end
    end)
end

local function refreshEsp()
    if not State.EspEnabled then return end
    for _, plr in ipairs(Players:GetPlayers()) do
        if plr ~= LocalPlayer and plr.Character then
            addEspToCharacter(plr.Character, plr)
        end
    end
    startEspUpdateLoop()
end

Players.PlayerAdded:Connect(function(plr)
    plr.CharacterAdded:Connect(function(char)
        if State.EspEnabled and plr ~= LocalPlayer then
            addEspToCharacter(char, plr)
        end
    end)
end)

for _, plr in ipairs(Players:GetPlayers()) do
    if plr ~= LocalPlayer then
        plr.CharacterAdded:Connect(function(char)
            if State.EspEnabled then addEspToCharacter(char, plr) end
        end)
    end
end

local EspTrack, EspKnob, setEspEnabled = createToggleSwitch(EspPage, UDim2.new(1, -64, 0, 57), false, function(enabled)
    State.EspEnabled = enabled
    if enabled then
        refreshEsp()
    else
        clearEsp()
    end
end)

