local originalTransparency = {}

local function setInvisible(enabled)
    local char = LocalPlayer.Character
    if not char then return end

    if enabled then
        for _, part in ipairs(char:GetDescendants()) do
            if part:IsA("BasePart") or part:IsA("Decal") then
                originalTransparency[part] = part.Transparency
                part.Transparency = 1
            end
        end
    else
        for part, t in pairs(originalTransparency) do
            if part and part.Parent then
                part.Transparency = t
            end
        end
        originalTransparency = {}
    end
end

local InvisibleTrack, InvisibleKnob, setInvisibleEnabled = createToggleSwitch(InvisiblePage, UDim2.new(1, -64, 0, 57), false, function(enabled)
    State.InvisibleEnabled = enabled
    setInvisible(enabled)
end)

