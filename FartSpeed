local ServerInfoLabel = newLabel(ServerInfoPanel, "Loading server info...", UDim2.new(1, -20, 1, 0), UDim2.new(0, 10, 0, 0), 13, true, Enum.TextXAlignment.Center)

task.spawn(function()
    tween(serverInfoScale, {Scale = 1}, 0.25, Enum.EasingStyle.Back)

    -- Ping (oficial, via Players:GetNetworkPing())
    local pingMs = "--"
    local okPing, pingResult = pcall(function()
        return LocalPlayer:GetNetworkPing()
    end)
    if okPing and pingResult then
        pingMs = math.floor(pingResult * 1000)
    end

    -- Região aproximada: o Roblox não expõe a localização física do servidor
    -- pra LocalScripts, então usamos a região detectada do jogador como estimativa
    local region = "--"
    local okRegion, regionResult = pcall(function()
        return game:GetService("LocalizationService"):GetCountryRegionForPlayerAsync(LocalPlayer)
    end)
    if okRegion and regionResult then
        region = regionResult
    end

    -- TPS estimado: medimos a frequência do Heartbeat por 1 segundo.
    -- Não é o TPS real do servidor (isso exigiria um script no servidor
    -- reportando via RemoteEvent), é uma estimativa client-side.
    local tpsCount = 0
    local tpsConn
    tpsConn = RunService.Heartbeat:Connect(function()
        tpsCount += 1
    end)
    task.wait(1)
    tpsConn:Disconnect()

    ServerInfoLabel.Text = string.format("Region: %s   Ping: %sms   TPS: ~%d", region, tostring(pingMs), tpsCount)

    task.wait(5)
    tween(serverInfoStroke, {Transparency = 1}, 0.3)
    tween(serverInfoScale, {Scale = 0}, 0.3, Enum.EasingStyle.Quad)
    task.wait(0.3)
    ServerInfoPanel:Destroy()
end)

