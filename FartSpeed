-- Hambúrguer: alterna Speed <-> Menu, roda o ícone
local hamburgerOpen = false
HamburgerBtn.MouseButton1Click:Connect(function()
    if State.CurrentPage == "Speed" then
        hamburgerOpen = true
        tween(HamburgerBtn, {Rotation = 90}, 0.25)
        showPage("Menu")
    else
        hamburgerOpen = false
        tween(HamburgerBtn, {Rotation = 0}, 0.25)
        showPage("Speed")
    end
end)

------------------------------------------------------------
-- ABRIR / FECHAR / MINIMIZAR (ANIMAÇÕES)
------------------------------------------------------------
local FULL_SIZE = UDim2.new(0, 300, 0, 230)
local MINI_SIZE = UDim2.new(0, 300, 0, 40)

local function openGui()
    State.IsClosed = false
    Main.Visible = true
    ShadowHolder.Visible = true
    Main.Size = UDim2.new(0, 0, 0, 0)
    Main.BackgroundTransparency = 1
    mainStroke.Transparency = 1
    tween(Main, {Size = FULL_SIZE, BackgroundTransparency = 0.15}, 0.35, Enum.EasingStyle.Back)
    tween(mainStroke, {Transparency = 0.75}, 0.35)
end

local function closeGui()
    State.IsClosed = true
    local t = tween(Main, {Size = UDim2.new(0, 0, 0, 0), BackgroundTransparency = 1}, 0.3, Enum.EasingStyle.Quint)
    tween(mainStroke, {Transparency = 1}, 0.3)
    task.delay(0.3, function()
        if State.IsClosed then
            Main.Visible = false
            ShadowHolder.Visible = false
        end
    end)
end

CloseBtn.MouseButton1Click:Connect(closeGui)

MinimizeBtn.MouseButton1Click:Connect(function()
    State.IsMinimized = not State.IsMinimized
    if State.IsMinimized then
        tween(Main, {Size = MINI_SIZE}, 0.3)
        tween(Content, {BackgroundTransparency = 1}, 0.15)
        Content.Visible = false
    else
        Content.Visible = true
        tween(Main, {Size = FULL_SIZE}, 0.3)
    end
end)

-- Tecla Q reabre a GUI
UserInputService.InputBegan:Connect(function(input, gameProcessed)
    if gameProcessed then return end
    if input.KeyCode == Enum.KeyCode.Q then
        if State.IsClosed then
            openGui()
        end
    end
end)

