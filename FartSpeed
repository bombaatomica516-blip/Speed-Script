    if flyVfxParticles then flyVfxParticles:Destroy(); flyVfxParticles = nil end
    if flyVfxLight then flyVfxLight:Destroy(); flyVfxLight = nil end
    if flyVfxAttachment0 then flyVfxAttachment0:Destroy(); flyVfxAttachment0 = nil end
    if flyVfxAttachment1 then flyVfxAttachment1:Destroy(); flyVfxAttachment1 = nil end
