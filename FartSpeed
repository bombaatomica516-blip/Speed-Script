        tween(knob, {Position = State.EspEnabled and UDim2.new(1,-20,0.5,-9) or UDim2.new(0,2,0.5,-9)}, 0.2)
        tween(track, {BackgroundColor3 = State.EspEnabled and Themes[State.CurrentTheme].Accent or Color3.fromRGB(70,70,75)}, 0.2)
        if State.EspEnabled then
            refreshEsp()
        else
            clearEsp()
        end
    end)
end

