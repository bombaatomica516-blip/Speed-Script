-- Registro de todos os toggles criados (preenchido por createToggleSwitch,
-- definida mais abaixo no arquivo) — permite que applyTheme atualize a cor
-- de qualquer toggle que esteja ligado no momento da troca de tema
local ToggleRegistry = {}
local StartStopBtn -- forward-declarado; a instância real é criada na seção do Aim Trainer

-- Muda o tema visual da GUI inteira (cores/tema), sem NUNCA mexer na
-- transparência do painel (que fica sempre travada em 25%), com uma
-- animação suave de transição entre o tema anterior e o novo
local function applyTheme(name)
    State.CurrentTheme = name
    local t = Themes[name]

    tween(Main, {BackgroundColor3 = t.Main}, 0.35)
    tween(SliderFill, {BackgroundColor3 = t.Accent}, 0.35)
    tween(knobStroke, {Color = t.Accent}, 0.35)

    for _, obj in ipairs(ScreenGui:GetDescendants()) do
        if (obj:IsA("TextLabel") or obj:IsA("TextButton")) and obj.Name ~= "CloseBtn" then
            tween(obj, {TextColor3 = t.Text}, 0.35)
        end
        if obj.Name:match("^Line%d") then
            tween(obj, {BackgroundColor3 = t.Text}, 0.35)
        end
    end

    -- atualiza qualquer toggle que esteja ligado agora, pra refletir a
    -- cor de destaque do novo tema
    for _, entry in ipairs(ToggleRegistry) do
        if entry.IsEnabled() then
            tween(entry.Track, {BackgroundColor3 = t.Accent}, 0.35)
        end
    end

    if StartStopBtn then
        tween(StartStopBtn, {BackgroundColor3 = t.Accent}, 0.35)
    end
end

-- Gera um preview visual pequeno e diferente pra cada card de tema, pra
-- não ficar tudo igual (sem usar imagens de obras protegidas — são só
-- formas geométricas geradas com as próprias cores do tema)
local function createThemePreview(parent, themeName, style)
    local theme = Themes[themeName]

    local preview = Instance.new("Frame")
    preview.Size = UDim2.new(0, 76, 0, 46)
    preview.BackgroundColor3 = theme.Main
    preview.BorderSizePixel = 0
    preview.ClipsDescendants = true
    preview.Parent = parent
    round(preview, 10)

    if style == "diagonal" then
        local band = Instance.new("Frame")
        band.Size = UDim2.new(1.6, 0, 0.9, 0)
        band.AnchorPoint = Vector2.new(0.5, 0.5)
        band.Position = UDim2.new(0.5, 0, 0.5, 0)
        band.Rotation = 35
        band.BackgroundColor3 = theme.Accent
        band.BorderSizePixel = 0
        band.Parent = preview
    elseif style == "corner" then
        local corner = Instance.new("Frame")
        corner.Size = UDim2.new(0.9, 0, 0.9, 0)
        corner.AnchorPoint = Vector2.new(1, 1)
        corner.Position = UDim2.new(1, 6, 1, 6)
        corner.Rotation = 45
        corner.BackgroundColor3 = theme.Accent
        corner.BorderSizePixel = 0
        corner.Parent = preview
    elseif style == "glow" then
        local glow = Instance.new("Frame")
        glow.Size = UDim2.new(0, 44, 0, 44)
        glow.AnchorPoint = Vector2.new(0.5, 0.5)
        glow.Position = UDim2.new(0.5, 0, 0.5, 0)
        glow.BackgroundColor3 = theme.Accent
        glow.BackgroundTransparency = 0.1
        glow.BorderSizePixel = 0
        glow.Parent = preview
        circle(glow)
    elseif style == "stripes" then
        for s = 1, 3 do
            local stripe = Instance.new("Frame")
            stripe.Size = UDim2.new(0, 12, 2, 0)
            stripe.Position = UDim2.new(0, (s * 22) - 14, -0.5, 0)
            stripe.Rotation = 18
            stripe.BackgroundColor3 = theme.Accent
            stripe.BorderSizePixel = 0
            stripe.Parent = preview
        end
    end

    return preview
end

