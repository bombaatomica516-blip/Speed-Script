local function showPage(name)
    if State.CurrentPage == name then return end

    local previousName = State.CurrentPage
    local previousPage = Pages[previousName]
    local previousScale = PageScales[previousName]

    -- animação de fechamento: a página atual encolhe de fora pro centro
    if previousPage and previousScale then
        tween(previousScale, {Scale = 0}, 0.2, Enum.EasingStyle.Quad)
        task.delay(0.2, function()
            previousPage.Visible = false
        end)
    end

    -- animação de abertura: a nova página nasce do centro pra fora
    local targetPage = Pages[name]
    local targetScale = PageScales[name]
    targetScale.Scale = 0
    targetPage.Visible = true
    tween(targetScale, {Scale = 1}, 0.3, Enum.EasingStyle.Back)

    State.CurrentPage = name
end

