    part.Material = Enum.Material.Neon
    part.Color = Themes[State.CurrentTheme].Accent
    part.CFrame = targetCFrame
    part.Parent = TargetsFolder

    local click = Instance.new("ClickDetector")
    click.MaxActivationDistance = 1000
    click.Parent = part

    click.MouseClick:Connect(function(clickingPlayer)
        if clickingPlayer ~= LocalPlayer or not aimSessionActive then return end
        if currentTarget ~= part then return end
        hits += 1
        updateStatsLabel()
        spawnTarget()
    end)

    currentTarget = part
end

local function stopAimTrainer()
    if not aimSessionActive then return end
    aimSessionActive = false
    destroyCurrentTarget()
    StartStopBtn.Text = "Start"

    local total = hits + misses
    if total > 0 then
        local accuracy = (hits / total) * 100
        if not bestAccuracy or accuracy > bestAccuracy then
            bestAccuracy = accuracy
            BestLabel.Text = string.format("Best accuracy: %d%%", math.floor(bestAccuracy))
        end
    end
end

local function startAimTrainer()
    if aimSessionActive then return end
    aimSessionActive = true
    hits, misses = 0, 0
    timeLeft = sessionDuration
    updateStatsLabel()
    TimeLabel.Text = "Time: "..timeLeft.."s"
    StartStopBtn.Text = "Stop"

    spawnTarget()

    task.spawn(function()
        while aimSessionActive and timeLeft > 0 do
            task.wait(1)
            if not aimSessionActive then break end
            timeLeft -= 1
            TimeLabel.Text = "Time: "..timeLeft.."s"
        end
        if aimSessionActive then
            stopAimTrainer()
        end
    end)
end

