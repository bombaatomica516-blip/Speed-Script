------------------------------------------------------------
-- ABRIR / FECHAR / MINIMIZAR (ANIMAÇÕES)
------------------------------------------------------------
local FULL_SIZE = UDim2.new(0, 300, 0, 300)
local MINI_SIZE = UDim2.new(0, 300, 0, 40)

-- Apaga todo o conteúdo do painel (exceto o ícone de hambúrguer), usado
-- durante a sequência de fechamento
local function fadeOutContent(duration)
    for _, obj in ipairs(Main:GetDescendants()) do
        if obj ~= HamburgerBtn and not obj:IsDescendantOf(HamburgerBtn) then
            if obj:IsA("TextLabel") or obj:IsA("TextButton") then
                tween(obj, {TextTransparency = 1, BackgroundTransparency = 1}, duration)
            elseif obj:IsA("Frame") and obj ~= TopBar then
                tween(obj, {BackgroundTransparency = 1}, duration)
            elseif obj:IsA("UIStroke") then
                tween(obj, {Transparency = 1}, duration)
            end
        end
    end
end

local function openGui()
    State.IsClosed = false

    -- reseta o ícone do hambúrguer e o conteúdo antes de abrir
    resetHamburgerLines()
    HamburgerBtn.Rotation = 0
    showPage("Speed")

    Main.Visible = true
    ShadowHolder.Visible = true
    Main.Size = UDim2.new(0, 0, 0, 0)
    Main.BackgroundTransparency = 1
    mainStroke.Transparency = 1
    tween(Main, {Size = FULL_SIZE, BackgroundTransparency = 0.25}, 0.35, Enum.EasingStyle.Back)
    tween(mainStroke, {Transparency = 0.75}, 0.35)
end

local function closeGui()
    if State.IsClosed then return end
    State.IsClosed = true
    HamburgerBtn.Rotation = 0
    stopAimTrainer()

    task.spawn(function()
        local step = 0.22
        local centerY = LineDefaults[2].Position

        -- Passo 1: as 3 linhas convergem ao centro enquanto o resto do
        -- painel desaparece
        fadeOutContent(step)
        tween(Lines[1], {Position = centerY}, step)
        tween(Lines[3], {Position = centerY}, step)
        task.wait(step)

        -- Passo 2: as 3 linhas giram para a vertical
        tween(Lines[1], {Rotation = 90}, 0.2)
        tween(Lines[2], {Rotation = 90}, 0.2)
        tween(Lines[3], {Rotation = 90}, 0.2)
        task.wait(0.2)

        -- Passo 3: as linhas de fora se fecham dos dois lados (centro pra fora ao contrário: encolhem pro centro)
        local line1Scale = Lines[1]:FindFirstChildOfClass("UIScale")
        local line3Scale = Lines[3]:FindFirstChildOfClass("UIScale")
        tween(line1Scale, {Scale = 0}, 0.22)
        tween(line3Scale, {Scale = 0}, 0.22)
        task.wait(0.22)

        -- Passo 4: a linha do meio volta pra horizontal e se fecha também dos dois lados
        tween(Lines[2], {Rotation = 0}, 0.18)
        task.wait(0.18)
        local line2Scale = Lines[2]:FindFirstChildOfClass("UIScale")
        tween(line2Scale, {Scale = 0}, 0.22)
        task.wait(0.22)

        Main.Visible = false
        ShadowHolder.Visible = false
    end)
end

