local FULL_SIZE = UDim2.new(0, 300, 0, 300)
local MINI_SIZE = UDim2.new(0, 300, 0, 40)

-- Guarda a transparência "normal" de cada elemento do painel, pra poder
-- restaurar exatamente como estava ao reabrir (corrige o bug de reabrir
-- e a GUI aparecer sem nada dentro)
local ContentDefaults = {}
local ShadowDefaults = {}

local function captureDefaults()
    for _, obj in ipairs(Main:GetDescendants()) do
        if obj ~= HamburgerBtn and not obj:IsDescendantOf(HamburgerBtn) then
            if obj:IsA("TextLabel") or obj:IsA("TextButton") then
                ContentDefaults[obj] = {Text = obj.TextTransparency, Background = obj.BackgroundTransparency}
            elseif obj:IsA("UIStroke") then
                ContentDefaults[obj] = {Stroke = obj.Transparency}
            elseif obj:IsA("Frame") and obj ~= TopBar then
                ContentDefaults[obj] = {Background = obj.BackgroundTransparency}
            end
        end
    end
    for _, layer in ipairs(ShadowHolder:GetChildren()) do
        if layer:IsA("Frame") then
            ShadowDefaults[layer] = layer.BackgroundTransparency
        end
    end
end

local function fadeOutContent(duration)
    for obj, defaults in pairs(ContentDefaults) do
        if obj and obj.Parent then
            if defaults.Text ~= nil then
                tween(obj, {TextTransparency = 1, BackgroundTransparency = 1}, duration)
            elseif defaults.Stroke ~= nil then
                tween(obj, {Transparency = 1}, duration)
            else
                tween(obj, {BackgroundTransparency = 1}, duration)
            end
        end
    end
end

local function fadeInContent(duration)
    for obj, defaults in pairs(ContentDefaults) do
        if obj and obj.Parent then
            if defaults.Text ~= nil then
                tween(obj, {TextTransparency = defaults.Text, BackgroundTransparency = defaults.Background}, duration)
            elseif defaults.Stroke ~= nil then
                tween(obj, {Transparency = defaults.Stroke}, duration)
            else
                tween(obj, {BackgroundTransparency = defaults.Background}, duration)
            end
        end
    end
end

local function fadeShadowOut(duration)
    for layer in pairs(ShadowDefaults) do
        tween(layer, {BackgroundTransparency = 1}, duration)
    end
end

local function fadeShadowIn(duration)
    for layer, defaultT in pairs(ShadowDefaults) do
        tween(layer, {BackgroundTransparency = defaultT}, duration)
    end
end

-- Deixa o painel já no "estado fechado" instantaneamente (sem animação),
-- usado só uma vez, antes da primeira abertura, pra abertura poder ser a
-- animação de fechamento tocada ao contrário
local function snapClosedState()
    Main.AnchorPoint = Vector2.new(0.5, 0.5)
    Main.Position = UDim2.new(0.5, 0, 0.5, 0)
    ShadowHolder.AnchorPoint = Vector2.new(0.5, 0.5)
    ShadowHolder.Position = UDim2.new(0.5, 0, 0.5, 0)
    Main.Size = UDim2.new(0, 0, 0, 0)
    mainStroke.Transparency = 1
    fadeOutContent(0)
    fadeShadowOut(0)

    local line1Scale = Lines[1]:FindFirstChildOfClass("UIScale")
    local line3Scale = Lines[3]:FindFirstChildOfClass("UIScale")
    line1Scale.Scale = 0
    line3Scale.Scale = 0
    Lines[1].Position = LineDefaults[2].Position
    Lines[3].Position = LineDefaults[2].Position
end

-- Fecha a GUI: reposiciona as 3 linhas (convergem ao centro), depois
-- esconde 2 delas (sobra só 1 risco) e então fecha o painel por completo,
-- até ser reativado pelo Q
local function closeGui()
    if State.IsClosed then return end
    State.IsClosed = true
    stopAimTrainer()

    task.spawn(function()
        local line1Scale = Lines[1]:FindFirstChildOfClass("UIScale")
        local line3Scale = Lines[3]:FindFirstChildOfClass("UIScale")

        -- Passo 1: reposiciona as 3 linhas (convergem pro centro)
        local centerPos = LineDefaults[2].Position
        tween(Lines[1], {Position = centerPos}, 0.2)
        tween(Lines[3], {Position = centerPos}, 0.2)
        task.wait(0.2)

        -- Passo 2: fecha 2 das linhas, sobrando só 1 risco
        tween(line1Scale, {Scale = 0}, 0.2)
        tween(line3Scale, {Scale = 0}, 0.2)
        task.wait(0.2)

        -- Passo 3: fecha a GUI por completo (só reabre com o Q)
        fadeOutContent(0.3)
        fadeShadowOut(0.3)
        tween(mainStroke, {Transparency = 1}, 0.3)
        tween(Main, {Size = UDim2.new(0, 0, 0, 0)}, 0.3, Enum.EasingStyle.Quint)
        task.wait(0.3)

        Main.Visible = false
        ShadowHolder.Visible = false
    end)
end

-- Abre a GUI: exatamente o inverso do fechamento, na ordem contrária
local function openGui()
    State.IsClosed = false
    Main.Visible = true
    ShadowHolder.Visible = true
    showPage("Speed")

    task.spawn(function()
        local line1Scale = Lines[1]:FindFirstChildOfClass("UIScale")
        local line3Scale = Lines[3]:FindFirstChildOfClass("UIScale")

        -- Passo reverso 3: a GUI abre por completo
        tween(Main, {Size = FULL_SIZE}, 0.35, Enum.EasingStyle.Back)
        fadeShadowIn(0.3)
        tween(mainStroke, {Transparency = 0.75}, 0.3)
        fadeInContent(0.3)
        task.wait(0.35)

        -- Passo reverso 2: as 2 linhas escondidas reaparecem
        tween(line1Scale, {Scale = 1}, 0.2)
        tween(line3Scale, {Scale = 1}, 0.2)
        task.wait(0.2)

        -- Passo reverso 1: as 3 linhas voltam pras posições originais
        tween(Lines[1], {Position = LineDefaults[1].Position}, 0.2)
        tween(Lines[3], {Position = LineDefaults[3].Position}, 0.2)
        task.wait(0.2)
    end)
end

-- Deixa tudo pronto no "estado fechado" antes da primeiríssima abertura,
-- pra ela já tocar a animação de abrir (o inverso do fechamento)
