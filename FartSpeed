local function createFlyVfx(root)
    local accent = Themes[State.CurrentTheme].Accent

    flyVfxAttachment0 = Instance.new("Attachment")
    flyVfxAttachment0.Position = Vector3.new(0, -1.4, 0.6)
    flyVfxAttachment0.Parent = root

    flyVfxAttachment1 = Instance.new("Attachment")
    flyVfxAttachment1.Position = Vector3.new(0, -1.4, -0.6)
    flyVfxAttachment1.Parent = root

    -- trilha de energia atrás do personagem
    flyVfxTrail = Instance.new("Trail")
    flyVfxTrail.Attachment0 = flyVfxAttachment0
    flyVfxTrail.Attachment1 = flyVfxAttachment1
    flyVfxTrail.Lifetime = 0.35
    flyVfxTrail.MinLength = 0
    flyVfxTrail.WidthScale = NumberSequence.new({
        NumberSequenceKeypoint.new(0, 1),
        NumberSequenceKeypoint.new(1, 0),
    })
    flyVfxTrail.Color = ColorSequence.new(accent)
    flyVfxTrail.Transparency = NumberSequence.new({
        NumberSequenceKeypoint.new(0, 0.2),
        NumberSequenceKeypoint.new(1, 1),
    })
    flyVfxTrail.Parent = root

    -- partículas de energia soltando enquanto voa
    flyVfxParticles = Instance.new("ParticleEmitter")
    flyVfxParticles.Texture = "rbxasset://textures/particles/sparkles_main.dds"
    flyVfxParticles.Color = ColorSequence.new(accent)
    flyVfxParticles.Size = NumberSequence.new({
        NumberSequenceKeypoint.new(0, 0.6),
        NumberSequenceKeypoint.new(1, 0),
    })
    flyVfxParticles.Transparency = NumberSequence.new({
        NumberSequenceKeypoint.new(0, 0.3),
        NumberSequenceKeypoint.new(1, 1),
    })
    flyVfxParticles.Lifetime = NumberRange.new(0.3, 0.6)
    flyVfxParticles.Rate = 40
    flyVfxParticles.Speed = NumberRange.new(2, 4)
    flyVfxParticles.SpreadAngle = Vector2.new(180, 180)
    flyVfxParticles.Parent = root

    -- brilho pulsante ao redor do personagem
    flyVfxLight = Instance.new("PointLight")
    flyVfxLight.Color = accent
    flyVfxLight.Range = 14
    flyVfxLight.Brightness = 2
    flyVfxLight.Parent = root

    task.spawn(function()
        while flyVfxLight and flyVfxLight.Parent do
            tween(flyVfxLight, {Brightness = 4}, 0.5, Enum.EasingStyle.Sine)
            task.wait(0.5)
            if not (flyVfxLight and flyVfxLight.Parent) then break end
            tween(flyVfxLight, {Brightness = 1.5}, 0.5, Enum.EasingStyle.Sine)
            task.wait(0.5)
        end
    end)
end

local flyPoseMotors = {} -- [Motor6D] = C0 original, pra restaurar depois

local function findShoulderMotors(char)
    local torso = char:FindFirstChild("UpperTorso") or char:FindFirstChild("Torso")
    if not torso then return nil, nil end
    local left = torso:FindFirstChild("LeftShoulder") or torso:FindFirstChild("Left Shoulder")
    local right = torso:FindFirstChild("RightShoulder") or torso:FindFirstChild("Right Shoulder")
    return left, right
end

local function applyFlyPose(char)
    local left, right = findShoulderMotors(char)
    if left then
        flyPoseMotors[left] = left.C0
        tween(left, {C0 = left.C0 * CFrame.Angles(math.rad(-65), 0, math.rad(12))}, 0.35, Enum.EasingStyle.Sine)
    end
    if right then
        flyPoseMotors[right] = right.C0
        tween(right, {C0 = right.C0 * CFrame.Angles(math.rad(-65), 0, math.rad(-12))}, 0.35, Enum.EasingStyle.Sine)
    end
end

local function resetFlyPose()
    for motor, originalC0 in pairs(flyPoseMotors) do
        if motor and motor.Parent then
            tween(motor, {C0 = originalC0}, 0.3, Enum.EasingStyle.Sine)
        end
    end
    flyPoseMotors = {}
end

local function stopFly()
    if flyConnection then flyConnection:Disconnect(); flyConnection = nil end
    if flyBodyVelocity then flyBodyVelocity:Destroy(); flyBodyVelocity = nil end
    if flyBodyGyro then flyBodyGyro:Destroy(); flyBodyGyro = nil end
    local char = LocalPlayer.Character
    local hum = char and char:FindFirstChildOfClass("Humanoid")
    if hum then hum.PlatformStand = false end
    destroyFlyVfx()
    resetFlyPose()
end

local function startFly()
    local char = LocalPlayer.Character
    if not char then return end
    local root = char:FindFirstChild("HumanoidRootPart")
    local hum = char:FindFirstChildOfClass("Humanoid")
    if not root or not hum then return end

    hum.PlatformStand = true
    createFlyVfx(root)
    applyFlyPose(char)

    flyBodyVelocity = Instance.new("BodyVelocity")
    flyBodyVelocity.MaxForce = Vector3.new(1,1,1) * math.huge
    flyBodyVelocity.Velocity = Vector3.new(0,0,0)
    flyBodyVelocity.Parent = root

    flyBodyGyro = Instance.new("BodyGyro")
    flyBodyGyro.MaxTorque = Vector3.new(1,1,1) * math.huge
    flyBodyGyro.P = 3000
    flyBodyGyro.Parent = root

    flyConnection = RunService.RenderStepped:Connect(function()
        if not State.FlyEnabled then return end
        local camera = workspace.CurrentCamera
        local moveDir = Vector3.new()
        if UserInputService:IsKeyDown(Enum.KeyCode.W) then moveDir += camera.CFrame.LookVector end
        if UserInputService:IsKeyDown(Enum.KeyCode.S) then moveDir -= camera.CFrame.LookVector end
        if UserInputService:IsKeyDown(Enum.KeyCode.A) then moveDir -= camera.CFrame.RightVector end
        if UserInputService:IsKeyDown(Enum.KeyCode.D) then moveDir += camera.CFrame.RightVector end
        if UserInputService:IsKeyDown(Enum.KeyCode.Space) then moveDir += Vector3.new(0,1,0) end
        if UserInputService:IsKeyDown(Enum.KeyCode.LeftControl) then moveDir += Vector3.new(0,-1,0) end

        -- leve zoom na câmera quando está voando em alta velocidade (sensação de impulso)
        local targetFOV = moveDir.Magnitude > 0 and (defaultCameraFOV + 6) or defaultCameraFOV
        if math.abs(camera.FieldOfView - targetFOV) > 0.5 then
            tween(camera, {FieldOfView = targetFOV}, 0.3)
        end

        if flyVfxParticles then
            flyVfxParticles.Enabled = moveDir.Magnitude > 0
        end

        if moveDir.Magnitude > 0 then
            moveDir = moveDir.Unit
        end
        flyBodyVelocity.Velocity = moveDir * State.Speed * 3

        -- inclina o corpo pra frente na direção do movimento, dando a
        -- sensação de "pose de voo" (tipo um moveset genérico de voo)
        local pitch = moveDir.Magnitude > 0 and math.rad(18) or 0
        flyBodyGyro.CFrame = camera.CFrame * CFrame.Angles(-pitch, 0, 0)
    end)
end

-- Helper de toggle reutilizável, com animação de posição/cor + um "punch"
-- de escala no botão pra dar mais feedback visual ao ligar/desligar
local function createToggleSwitch(parent, position, default, onChange)
    local track = Instance.new("Frame")
    track.Size = UDim2.new(0, 44, 0, 22)
    track.Position = position
    track.BackgroundColor3 = default and Themes[State.CurrentTheme].Accent or Color3.fromRGB(70,70,75)
    track.BorderSizePixel = 0
    track.Parent = parent
    round(track, 11)

    local knob = Instance.new("Frame")
    knob.AnchorPoint = Vector2.new(0.5, 0.5)
    knob.Size = UDim2.new(0, 18, 0, 18)
    knob.Position = default and UDim2.new(1, -11, 0.5, 0) or UDim2.new(0, 11, 0.5, 0)
    knob.BackgroundColor3 = Color3.fromRGB(255,255,255)
    knob.Parent = track
    circle(knob)

    local btn = Instance.new("TextButton")
    btn.BackgroundTransparency = 1
    btn.Size = UDim2.new(1, 0, 1, 0)
    btn.Text = ""
    btn.Parent = track

    local enabled = default

    local function applyVisual()
        tween(knob, {Position = enabled and UDim2.new(1, -11, 0.5, 0) or UDim2.new(0, 11, 0.5, 0)}, 0.2)
        tween(track, {BackgroundColor3 = enabled and Themes[State.CurrentTheme].Accent or Color3.fromRGB(70,70,75)}, 0.2)

        -- punch de escala no botão pra reforçar o "clique"
        tween(knob, {Size = UDim2.new(0, 23, 0, 23)}, 0.1, Enum.EasingStyle.Quad)
        task.delay(0.1, function()
            tween(knob, {Size = UDim2.new(0, 18, 0, 18)}, 0.15, Enum.EasingStyle.Back)
        end)
    end

    -- Permite ligar/desligar programaticamente (usado pelos atalhos de teclado),
    -- animando igual ao clique do mouse
    local function setEnabled(value)
        if enabled == value then return end
        enabled = value
        applyVisual()
        if onChange then onChange(enabled) end
    end

    btn.MouseButton1Click:Connect(function()
        setEnabled(not enabled)
    end)

    table.insert(ToggleRegistry, {Track = track, IsEnabled = function() return enabled end})

    return track, knob, setEnabled
end

