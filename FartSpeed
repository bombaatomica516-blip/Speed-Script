-- Pasta isolada só pros alvos do treino (limpa qualquer resto de execuções anteriores)
local oldRange = workspace:FindFirstChild("AimTrainerRange")
if oldRange then oldRange:Destroy() end

local TargetsFolder = Instance.new("Folder")
TargetsFolder.Name = "AimTrainerRange"
TargetsFolder.Parent = workspace

local aimSessionActive = false
local currentTarget = nil
local hits, misses = 0, 0
local sessionDuration = 30
local timeLeft = sessionDuration
local bestAccuracy = nil
local mouse = LocalPlayer:GetMouse()

local function updateStatsLabel()
    local total = hits + misses
    local accuracy = total > 0 and math.floor((hits / total) * 100) or 0
    StatsLabel.Text = string.format("Hits: %d   Misses: %d   Accuracy: %d%%", hits, misses, accuracy)
end

local function destroyCurrentTarget()
    if currentTarget then
        currentTarget:Destroy()
        currentTarget = nil
    end
end

local function spawnTarget()
    destroyCurrentTarget()

    local camera = workspace.CurrentCamera
    if not camera then return end

    local offsetX = math.random(-8, 8)
    local offsetY = math.random(-3, 4)
    local distance = math.random(12, 22)

    local targetCFrame = camera.CFrame * CFrame.new(offsetX, offsetY, -distance)

    local part = Instance.new("Part")
    part.Name = "AimTarget"
    part.Shape = Enum.PartType.Ball
    part.Size = Vector3.new(2, 2, 2)
    part.Anchored = true
    part.CanCollide = false
    part.Material = Enum.Material.Neon
    part.Color = Themes[State.CurrentTheme].Accent
    part.CFrame = targetCFrame
    part.Parent = TargetsFolder

    local click = Instance.new("ClickDetector")
    click.MaxActivationDistance = 1000
    click.Parent = part

    click.MouseClick:Connect(function(clickingPlayer)
        if clickingPlayer ~= LocalPlayer or not aimSessionActive then return end
        if currentTarget ~= part then return end
        hits += 1
        updateStatsLabel()
        spawnTarget()
    end)

    currentTarget = part
end

local function stopAimTrainer()
    if not aimSessionActive then return end
    aimSessionActive = false
    destroyCurrentTarget()
    StartStopBtn.Text = "Start"

    local total = hits + misses
    if total > 0 then
        local accuracy = (hits / total) * 100
        if not bestAccuracy or accuracy > bestAccuracy then
            bestAccuracy = accuracy
            BestLabel.Text = string.format("Best accuracy: %d%%", math.floor(bestAccuracy))
        end
    end
end

local function startAimTrainer()
    if aimSessionActive then return end
    aimSessionActive = true
    hits, misses = 0, 0
    timeLeft = sessionDuration
    updateStatsLabel()
    TimeLabel.Text = "Time: "..timeLeft.."s"
    StartStopBtn.Text = "Stop"

    spawnTarget()

    task.spawn(function()
        while aimSessionActive and timeLeft > 0 do
            task.wait(1)
            if not aimSessionActive then break end
            timeLeft -= 1
            TimeLabel.Text = "Time: "..timeLeft.."s"
        end
        if aimSessionActive then
            stopAimTrainer()
        end
    end)
end

-- Qualquer clique que não seja no alvo atual conta como erro
mouse.Button1Down:Connect(function()
    if not aimSessionActive then return end
    local target = mouse.Target
    if target ~= currentTarget then
        misses += 1
        updateStatsLabel()
    end
end)

StartStopBtn.MouseButton1Click:Connect(function()
    if aimSessionActive then
        stopAimTrainer()
    else
        startAimTrainer()
    end
end)

