local function updateSpeedValueLabel(v)
    SpeedValue.Text = tostring(math.floor(v))
end

local function applySpeed(v)
    State.Speed = v
    updateSpeedValueLabel(v)
    local char = LocalPlayer.Character
    local hum = char and char:FindFirstChildOfClass("Humanoid")
    if hum then
        hum.WalkSpeed = v
    end
