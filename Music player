-- ============================================================
-- LÓGICA DO PLAYER
-- ============================================================

local function getSongName(id)
    local ok, info = pcall(function()
        return MarketplaceService:GetProductInfo(tonumber(id), Enum.InfoType.Asset)
    end)
    if ok and info and info.Name then
        return info.Name
    end
    return "Música " .. tostring(id)
end

local function playSong(id)
    if not id or id == "" then return end

    -- Pede ao servidor pra criar o som no seu personagem.
    -- Assim, qualquer jogador perto de você também vai ouvir.
    musicRemote:FireServer("Play", id)

    currentSongId = id
    idBox.Text = id
    nowPlayingLabel.Text = "Tocando: " .. getSongName(id)
end

local function stopSong()
    musicRemote:FireServer("Stop")
    nowPlayingLabel.Text = "Nada tocando"
end

local function findCurrentIndex()
    for i, song in ipairs(playlist) do
        if song.id == currentSongId then
            return i
        end
    end
    return 0
end

local function renderPlaylist()
    for _, child in ipairs(scrollFrame:GetChildren()) do
        if child:IsA("Frame") then
            child:Destroy()
        end
    end

    for i, song in ipairs(playlist) do
        local row = Instance.new("Frame")
        row.Size = UDim2.new(1, 0, 0, 34)
        row.BackgroundColor3 = COLOR_PANEL
        row.BorderSizePixel = 0
        row.LayoutOrder = i
        row.Parent = scrollFrame
        corner(8, row)

        local nameLabel = Instance.new("TextLabel")
        nameLabel.Size = UDim2.new(1, -60, 1, 0)
        nameLabel.Position = UDim2.new(0, 8, 0, 0)
        nameLabel.BackgroundTransparency = 1
        nameLabel.Font = Enum.Font.Gotham
        nameLabel.Text = song.name or ("Música " .. song.id)
        nameLabel.TextSize = 12
        nameLabel.TextColor3 = COLOR_TEXT
        nameLabel.TextXAlignment = Enum.TextXAlignment.Left
        nameLabel.TextTruncate = Enum.TextTruncate.AtEnd
        nameLabel.Parent = row

        local rowPlayBtn = Instance.new("TextButton")
        rowPlayBtn.Size = UDim2.new(0, 24, 0, 24)
        rowPlayBtn.Position = UDim2.new(1, -54, 0.5, -12)
        rowPlayBtn.BackgroundColor3 = COLOR_PLAY
        rowPlayBtn.Font = Enum.Font.GothamBold
        rowPlayBtn.Text = ""
        rowPlayBtn.TextSize = 12
        rowPlayBtn.TextColor3 = Color3.new(1, 1, 1)
        rowPlayBtn.Parent = row
        corner(6, rowPlayBtn)

        local rowRemoveBtn = Instance.new("TextButton")
        rowRemoveBtn.Size = UDim2.new(0, 24, 0, 24)
        rowRemoveBtn.Position = UDim2.new(1, -26, 0.5, -12)
        rowRemoveBtn.BackgroundColor3 = COLOR_STOP
        rowRemoveBtn.Font = Enum.Font.GothamBold
        rowRemoveBtn.Text = "✕"
        rowRemoveBtn.TextSize = 12
        rowRemoveBtn.TextColor3 = Color3.new(1, 1, 1)
        rowRemoveBtn.Parent = row
        corner(6, rowRemoveBtn)

        rowPlayBtn.MouseButton1Click:Connect(function()
            playSong(song.id)
        end)

        rowRemoveBtn.MouseButton1Click:Connect(function()
            table.remove(playlist, i)
            renderPlaylist()
        end)
    end
end

playButton.MouseButton1Click:Connect(function()
    local id = idBox.Text:match("%d+")
    playSong(id)
end)

stopButton.MouseButton1Click:Connect(function()
    stopSong()
end)

addButton.MouseButton1Click:Connect(function()
    local id = idBox.Text:match("%d+")
    if id then
        table.insert(playlist, {id = id, name = getSongName(id)})
        renderPlaylist()
    end
end)

backButton.MouseButton1Click:Connect(function()
    if #playlist == 0 then return end
    local idx = findCurrentIndex()
    idx = idx - 1
    if idx < 1 then idx = #playlist end
    playSong(playlist[idx].id)
end)

nextButton.MouseButton1Click:Connect(function()
    if #playlist == 0 then return end
    local idx = findCurrentIndex()
    idx = idx + 1
    if idx > #playlist then idx = 1 end
    playSong(playlist[idx].id)
end)

toggleButton.MouseButton1Click:Connect(function()
    playlistOpen = not playlistOpen

    local targetWidth = playlistOpen and 190 or 0
    local tween = TweenService:Create(
        playlistContainer,
        TweenInfo.new(0.3, Enum.EasingStyle.Quad, Enum.EasingDirection.Out),
        {Size = UDim2.new(0, targetWidth, 1, 0)}
    )
    tween:Play()

    toggleButton.Text = playlistOpen and "❯" or "❮"
end)

idBox.FocusLost:Connect(function(enterPressed)
    if enterPressed then
        local id = idBox.Text:match("%d+")
        playSong(id)
    end
end)
