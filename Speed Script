-- HOVER EFFECT
----------------------------------------------------

local function Hover(button)

	local normal = button.Size

	button.MouseEnter:Connect(function()

		TweenService:Create(
			button,
			TweenInfo.new(
				0.15,
				Enum.EasingStyle.Quad
			),
			{
				Size = UDim2.new(
					0,
					34,
					0,
					34
				)
			}
		):Play()

	end)


	button.MouseLeave:Connect(function()

		TweenService:Create(
			button,
			TweenInfo.new(
				0.15,
				Enum.EasingStyle.Quad
			),
			{
				Size = normal
			}
		):Play()

	end)

end


