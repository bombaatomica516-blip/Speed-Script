----------------------------------------------------

local closed = false


close.MouseButton1Click:Connect(function()


	if closed then
		return
	end


	closed = true


	BlurOut()


	local animation =
		TweenService:Create(

			frame,

			TweenInfo.new(
				0.35,
				Enum.EasingStyle.Back,
				Enum.EasingDirection.In
			),

			{

				Size = UDim2.new(
					0,
					0,
					0,
					0
				),

				BackgroundTransparency = 1

			}

		)


	animation:Play()


	animation.Completed:Wait()


	frame.Visible = false


	frame.Size =
		UDim2.new(
			0,
			330,
			0,
			170
		)


	frame.BackgroundTransparency =
		0.25


end)



----------------------------------------------------
-- ABRIR NOVAMENTE COM Q
----------------------------------------------------

UserInputService.InputBegan:Connect(function(input, gameProcessed)


	if gameProcessed then
		return
	end



	if input.KeyCode ==
		Enum.KeyCode.Q then



		if not frame.Visible then


			frame.Visible = true


			frame.Size =
				UDim2.new(
					0,
					0,
					0,
					0
				)


			BlurIn()



			TweenService:Create(

				frame,

				TweenInfo.new(
					0.45,
					Enum.EasingStyle.Back,
					Enum.EasingDirection.Out
				),

				{

					Size =
						UDim2.new(
							0,
							330,
							0,
							170
						),

					BackgroundTransparency =
						0.25

				}

			):Play()


			closed = false


		end


	end


end)
